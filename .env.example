# Server
PORT=3101
HOST=127.0.0.1
YANDEX_AUTH_SESSION_TTL_MS=600000

# Logging
LOG_ENABLED=false
LOG_LEVEL=info

# App access
REQUIRE_ACCESS_AUTH=false
ACCESS_USERNAME=
ACCESS_PASSWORD=
ACCESS_BEARER_TOKEN=
IP_ALLOWLIST=

# API protection
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_BUCKET_LIMIT=10000
MAX_JSON_BODY_BYTES=8192
# Optional for local development. In production this must be set explicitly.
PRIMARY_TOKEN_SEAL_SECRET=
PRIMARY_TOKEN_REPLAY_TTL_MS=86400000

# Session exchange
TOKEN_BY_SESSION_CLIENT_ID=
TOKEN_BY_SESSION_CLIENT_SECRET=

# Passport and device
PASSPORT_SDK_VERSION=6.32.2
PASSPORT_APP_ID=ru.yandex.key
PASSPORT_APP_VERSION=24023131
PASSPORT_IOS_VERSION=26.4
DEVICE_MODEL=iPad8,6
DEVICE_NAME=iPad

# Yandex Music
MUSIC_CLIENT_ID=
MUSIC_CLIENT_SECRET=
MUSIC_APP_ID=
MUSIC_DEVICE_ID=
MUSIC_AM_VERSION_NAME=7.33.2(733022870)
MUSIC_APP_VERSION=24023131
MUSIC_AUTH_USER_AGENT=com.yandex.mobile.auth.sdk/7.33.2.733022870
MUSIC_DEVICE_PLATFORM=ios

# Shedevrum
SHEDEVRUM_CLIENT_ID=
SHEDEVRUM_CLIENT_SECRET=
SHEDEVRUM_APP_ID=
SHEDEVRUM_APP_VERSION=
SHEDEVRUM_UUID=
SHEDEVRUM_DEVICE_ID=
SHEDEVRUM_DEVICE_PLATFORM=iPad
SHEDEVRUM_MANUFACTURER=Apple
SHEDEVRUM_IOS_VERSION=26.4
